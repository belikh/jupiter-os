result
result-*
.direnv/

# VM disk images + OVMF EFI variable store (build artifacts from
# `make test-<host>` / scripts/boot-smoke.sh; vmVariant boots UEFI)
*.qcow2
*-efi-vars.fd

# Real pallene build-server tokens — materialized from sops by `make
# pallene-iso` around the ISO build, then deleted. Only the *.placeholder
# files are committed (so eval always resolves); the real plaintext must
# never land in the store or git.
secrets/pallene-secrets/*
!secrets/pallene-secrets/*.placeholder
