// Phosphor theme (task.md T3.1 / slint_layout_spec.md §1). The active room
// colour is written into `primary` from Rust at startup via
// `Theme::get(&ui).set_primary(room_color(...))`; `primary-dim`/`primary-soft`
// re-bind reactively so every widget that reads them recolours for free.
export global Theme {
    in-out property <color> phosphor-amber:  #ffb642;
    in-out property <color> phosphor-green:  #1aff1a;
    in-out property <color> phosphor-blue:   #3399ff;
    in-out property <color> phosphor-purple: #b366ff;

    // Active room theme; mutated from Rust at startup.
    in-out property <color> primary: phosphor-amber;
    in-out property <color> primary-dim: primary.transparentize(0.6);
    in-out property <color> primary-soft: primary.transparentize(0.85);

    in-out property <color> background: #0c0700;
    in-out property <color> alert: #ff3333;
    // mid-tier warning colour (between primary and alert) — the YAML gauges use
    // --fallout-warn for the middle segment. Yellow-ish so it reads distinct
    // from the room primary (which is amber/green/blue/purple per room).
    in-out property <color> warn: #ffcc00;
    // dimmed track colour for gauge backgrounds / unfilled segments.
    in-out property <color> track: primary.transparentize(0.78);

    in-out property <string> font-family: "Monofonto";
    in-out property <length>  font-size-base: 14px;
}
