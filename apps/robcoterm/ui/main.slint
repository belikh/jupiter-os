// Root window. The bedroom quarters overview mounts here in Phase C2; for T3.1
// this exists so slint-build compiles the Theme global and Rust can reach it
// via Theme::get(&ui). background + a single label prove the binding live.
import { Theme } from "theme.slint";

export { Theme }

export component App inherits Window {
    background: Theme.background;
    Text {
        text: "JUPITER";
        color: Theme.primary;
        font-family: Theme.font-family;
        font-size: 24px;
    }
}
