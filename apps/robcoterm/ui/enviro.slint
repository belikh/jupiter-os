import { Theme } from "theme.slint";
import { PageId } from "pages.slint";
import { StatusBar } from "components/status_bar.slint";
import { NavBar } from "components/nav_bar.slint";
import { Meter } from "components/meter.slint";

// One telemetry gauge: title + numeric readout + a level-coloured meter with
// warn/alert zone ticks. Min/max/warn-at/alert-at are UI constants from the
// YAML (`environment` view); Rust only delivers the raw float. Level is
// monotonic-high: value >= alert-at -> alert, >= warn-at -> warn, else ok.
component GaugeCell inherits Rectangle {
    in property <string> title: "";
    in property <float> value: 0.0;
    in property <float> min: 0.0;
    in property <float> max: 1.0;
    in property <string> unit: "";
    in property <float> warn-at: 9999999.0;
    in property <float> alert-at: 9999999.0;

    property <string> level:
        root.value >= root.alert-at ? "alert"
      : root.value >= root.warn-at ? "warn"
      : "ok";
    property <float> frac: (root.value - root.min) / (root.max - root.min);

    border-width: 1px;
    border-color: root.level == "alert" ? Theme.alert : root.level == "warn" ? Theme.warn : Theme.primary;
    background: Theme.background;

    VerticalLayout {
        padding: 10px;
        spacing: 6px;

        Text {
            text: root.title;
            color: Theme.primary-dim;
            font-family: Theme.font-family;
            font-size: Theme.font-size-base;
        }
        Text {
            text: "\{round(root.value)} \{root.unit}";
            color: root.level == "alert" ? Theme.alert : root.level == "warn" ? Theme.warn : Theme.primary;
            font-family: Theme.font-family;
            font-size: 22px;
            vertical-alignment: center;
        }
        Meter {
            value: root.frac;
            fill-color: root.level == "alert" ? Theme.alert : root.level == "warn" ? Theme.warn : Theme.primary;
            warn-tick: (root.warn-at - root.min) / (root.max - root.min);
            alert-tick: (root.alert-at - root.min) / (root.max - root.min);
        }
    }
}

// Bedroom environment page (jupiter-room.yaml `environment` view): 4 air-quality
// gauges. Read-only — no ServiceCall round-trip, just sensor -> meter binding.
export component EnviroPage inherits Rectangle {
    in property <PageId> current-page: PageId.enviro;
    in property <string> connection: "connected";

    in property <float> co2: 400.0;
    in property <float> pm25: 0.0;
    in property <float> temperature: 20.0;
    in property <float> humidity: 50.0;

    callback page-requested(PageId);

    background: Theme.background;

    VerticalLayout {
        spacing: 0px;

        StatusBar {
            title: "JUPITER QUARTERS // ENVIRONMENT";
        }

        GridLayout {
            spacing: 8px;
            padding: 8px;

            Row {
                GaugeCell {
                    title: "CO2";
                    value: root.co2;
                    min: 400.0;
                    max: 2000.0;
                    unit: "ppm";
                    warn-at: 800.0;
                    alert-at: 1200.0;
                }
                GaugeCell {
                    title: "PM2.5";
                    value: root.pm25;
                    min: 0.0;
                    max: 150.0;
                    unit: "µg";
                    warn-at: 25.0;
                    alert-at: 75.0;
                }
            }
            Row {
                GaugeCell {
                    // YAML is non-monotonic (cold=warn, hot=alert); flag the
                    // hot end as alert, leave cold unflagged.
                    title: "TEMPERATURE";
                    value: root.temperature;
                    min: 10.0;
                    max: 35.0;
                    unit: "°C";
                    alert-at: 26.0;
                }
                GaugeCell {
                    // YAML flags both dry and humid; flag the humid end.
                    title: "HUMIDITY";
                    value: root.humidity;
                    min: 0.0;
                    max: 100.0;
                    unit: "%";
                    warn-at: 65.0;
                    alert-at: 80.0;
                }
            }
        }

        NavBar {
            current: root.current-page;
            page-requested(p) => {
                root.page-requested(p);
            }
        }
    }

    if root.connection != "connected" : Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: 28px;
        background: Theme.alert;
        Text {
            text: root.connection == "connecting" ? "▒ RECONNECTING ▒" : "▒ LINK DOWN ▒";
            color: black;
            font-family: Theme.font-family;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
