import { Theme } from "../theme.slint";

// Vault Boy mascot. Renders one of the bundled FO76 PNGs (embedded at compile
// time via @image-url, resolved by slint-build from apps/robcoterm/assets/vaultboy)
// based on `mood`, colourized to the room's primary so the full-colour cartoon
// reads as monochrome phosphor like the rest of the terminal:
//   "idle"/"sleeping" -> lone wanderer, "home"/"occupied" -> camp (thumbs up),
//   "alert"           -> first-aid,        "radiation"     -> geiger counter.
// Multiple Image elements with visibility guards (rather than one dynamic
// source) because @image-url is resolved at compile time.
export component VaultBoyMascot inherits Rectangle {
    in property <string> mood: "idle";
    background: transparent;

    Image {
        source: @image-url("../../assets/vaultboy/FO76_vaultboy_lonewanderer.png");
        visible: root.mood == "idle" || root.mood == "sleeping";
        image-fit: contain;
        colorize: Theme.primary;
    }
    Image {
        source: @image-url("../../assets/vaultboy/FO76_vaultboy_camp.png");
        visible: root.mood == "home" || root.mood == "occupied";
        image-fit: contain;
        colorize: Theme.primary;
    }
    Image {
        source: @image-url("../../assets/vaultboy/FO76_vaultboy_firstaid.png");
        visible: root.mood == "alert";
        image-fit: contain;
        colorize: Theme.warn;
    }
    Image {
        source: @image-url("../../assets/vaultboy/FO76_vaultboy_geiger.png");
        visible: root.mood == "radiation";
        image-fit: contain;
        colorize: Theme.alert;
    }
}
